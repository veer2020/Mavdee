; Database
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=YOUR_DB_PASSWORD_HERE

; Cron secret - for abandoned cart script
CRON_SECRET=your_strong_random_string_here

; Email SMTP - optional, used by PHPMailer
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
SMTP_ENCRYPTION=tls

; Site
SITE_NAME="Mavdee"
SITE_URL=https://mavdee.com
CURRENCY="₹"
APP_DEBUG=false

; Razorpay payment gateway
RZP_ENABLED=true
RZP_KEY_ID=YOUR_RZP_KEY_ID_HERE
RZP_KEY_SECRET=YOUR_RZP_SECRET_HERE
RZP_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

; Google OAuth (leave blank to disable Google Sign-In)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=https://mavdee.com/api/auth/google_callback.php

; Redis cache / rate limiter (leave blank to use file-based fallback)
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

; Delhivery shipping environment: 'sandbox' or 'production'
DELHIVERY_ENV=production
; Replace with the exact name copied from your Delhivery dashboard
DELHIVERY_FACILITY_NAME="Mavdee"

